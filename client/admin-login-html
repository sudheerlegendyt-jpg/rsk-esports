<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Login | RSK ESPORTS</title>

<link rel="stylesheet" href="style.css">

<style>
body{
    background:#0d0d0d;
    color:white;
    font-family:Arial,sans-serif;
}

.login-box{
    width:380px;
    margin:80px auto;
    background:#1b1b1b;
    padding:30px;
    border-radius:12px;
    border:2px solid red;
}

.login-box h2{
    text-align:center;
    color:red;
    margin-bottom:20px;
}

.login-box input{
    width:100%;
    padding:12px;
    margin:10px 0;
    background:#111;
    color:white;
    border:1px solid #444;
    border-radius:6px;
}

.login-box button{
    width:100%;
    padding:12px;
    background:red;
    color:white;
    border:none;
    border-radius:6px;
    font-size:18px;
    cursor:pointer;
}

.login-box button:hover{
    background:#ff3333;
}
</style>

</head>
<body>

<header>
<h1 style="text-align:center;color:red;margin-top:20px;">🎮 RSK ESPORTS ADMIN</h1>
</header>

<div class="login-box">

<h2>Admin Login</h2>

<form id="adminLogin">

<input type="email" id="email" placeholder="Admin Email" required>

<input type="password" id="password" placeholder="Password" required>

<button type="submit">Login</button>

</form>

</div>

<script>

document.getElementById("adminLogin").addEventListener("submit",function(e){

e.preventDefault();

let email=document.getElementById("email").value;
let password=document.getElementById("password").value;

if(email==="admin@rskesports.com" && password==="Admin@123"){
    alert("Admin Login Successful");
    window.location.href="admin-dashboard.html";
}else{
    alert("Invalid Admin Email or Password");
}

});

</script>

</body>
</html>
